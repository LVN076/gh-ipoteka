# ============================================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ — скопируйте этот файл как .env.local
# и заполните своими данными
# ============================================================

# ────────────────────────────────────────────────────────────
# Bitrix24
# ────────────────────────────────────────────────────────────
# Webhook URL для создания лидов
# Пример: https://yourdomain.bitrix24.ru/rest/1/yoursecretkey/crm.lead.add.json
NEXT_PUBLIC_BITRIX24_WEBHOOK=https://YOUR_DOMAIN.bitrix24.ru/rest/1/YOUR_KEY/crm.lead.add.json

# ────────────────────────────────────────────────────────────
# Яндекс Метрика
# ────────────────────────────────────────────────────────────
# ID счётчика (только цифры). Пример: 12345678
NEXT_PUBLIC_YM_ID=

# ────────────────────────────────────────────────────────────
# ВКонтакте — публичные настройки
# ────────────────────────────────────────────────────────────
# Ссылка на группу ВКонтакте
NEXT_PUBLIC_VK_GROUP_URL=https://vk.com/goodhouse

# Ссылка на Telegram (опционально)
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/goodhouse

# ────────────────────────────────────────────────────────────
# ВКонтакте — СЕРВЕРНЫЕ секреты (НЕ добавлять NEXT_PUBLIC_!)
# Получить в https://id.vk.com/about/business/go/apps
# ────────────────────────────────────────────────────────────

# ID вашего VK-приложения (только цифры)
# Пример: 54522246
VK_CLIENT_ID=YOUR_VK_APP_ID

# Секретный ключ VK-приложения (вкладка "Настройки" → "Защищённый ключ")
VK_CLIENT_SECRET=YOUR_VK_CLIENT_SECRET

# Сервисный ключ доступа (вкладка "Настройки" → "Сервисный токен")
# Используется для серверной проверки groups.isMember
VK_SERVICE_TOKEN=YOUR_VK_SERVICE_TOKEN

# Числовой ID или slug вашей группы ВКонтакте (без минуса и https://vk.com/)
# Пример: goodhouse_yar  или  143228474
VK_GROUP_ID=goodhouse_yar

# Callback URL — должен совпадать с настройками в VK-приложении
# Пример: https://your-domain.vercel.app/api/vk-callback
VK_REDIRECT_URI=https://YOUR_DOMAIN.vercel.app/api/vk-callback
