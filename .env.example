# ============================================================
# ПЕРЕМЕННЫЕ ОКРУЖЕНИЯ — скопируйте этот файл как .env.local
# и заполните своими данными
# ============================================================

# Bitrix24 webhook URL для создания лидов
# Пример: https://yourdomain.bitrix24.ru/rest/1/yoursecretkey/crm.lead.add.json
NEXT_PUBLIC_BITRIX24_WEBHOOK=https://YOUR_DOMAIN.bitrix24.ru/rest/1/YOUR_KEY/crm.lead.add.json

# Яндекс Метрика — ID счётчика (только цифры)
# Пример: 12345678
NEXT_PUBLIC_YM_ID=

# Ссылка на группу ВКонтакте
# Пример: https://vk.com/goodhouse
NEXT_PUBLIC_VK_GROUP_URL=https://vk.com/goodhouse

# Ссылка на Telegram (для будущей адаптации)
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/goodhouse
